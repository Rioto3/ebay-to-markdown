{
  "manifest_version": 2,
  "name": "eBay-MD",
  "version": "1.0",
  "description": "Convert eBay product pages to markdown format",
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "notifications",
    "downloads"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.ebay.com/itm/*"],
      "js": ["content.js"]
    }
  ],
  "browser_action": {
    "default_icon": {
      "19": "icons/icon-19.png",
      "38": "icons/icon-38.png"
    },
    "default_title": "eBay-MD"
  }
}